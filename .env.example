# Discord Bot
DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_bot_client_id_here

# Lavalink v4 Configuration
LAVA_HOST=localhost
LAVA_PORT=2333
LAVA_PASS=youshallnotpass
LAVA_SECURE=false

# Spotify (via kazagumo-spotify)
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Error Logging
ERROR_WEBHOOK_URL=your_discord_webhook_url_here

# Optional: Developer user IDs (comma-separated) for dev-only commands
DEV_IDS=123456789012345678,987654321098765432

# Optional: Log channel IDs
LAVALINK_LOG_CHANNEL_ID=your_lavalink_log_channel_id
COMMAND_LOG_CHANNEL_ID=your_command_log_channel_id

# Optional: Custom images
NOW_PLAYING_BANNER_URL=https://i.imgur.com/your-banner.png
DEFAULT_THUMBNAIL_URL=https://i.imgur.com/AfFp7pu.png

# Optional: Support server invite link
SUPPORT_SERVER_INVITE=https://discord.gg/your-server

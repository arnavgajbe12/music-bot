# Discord Bot
DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_bot_client_id_here

# Lavalink v4 Configuration (Primary Node)
LAVA_HOST=localhost
LAVA_PORT=2333
LAVA_PASS=youshallnotpass
LAVA_SECURE=false

# Lavalink v4 Configuration (Secondary/Backup Node — optional)
# LAVA2_HOST=backup.lavalink.host
# LAVA2_PORT=2333
# LAVA2_PASS=youshallnotpass
# LAVA2_SECURE=false

# Spotify (via LavaSrc)
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Error Logging
ERROR_WEBHOOK_URL=your_discord_webhook_url_here

# Lavalink Event Logging (optional — send Lavalink track/node events to a Discord channel)
# LAVALINK_LOG_CHANNEL_ID=your_discord_channel_id_here
